# ═══════════════════════════════════════════════════════════════
# prt_services_simulator — .gitignore
# Java (Spring Boot / Maven) + Dagger (Go) CI/CD pipeline
# ═══════════════════════════════════════════════════════════════

# ── Credentials & secrets — NEVER commit ──────────────────────
dagger_go/credentials/
.env
.env.*
!.env.example

# ── Java / Maven ──────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ── IDEs ──────────────────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.project
.classpath
.settings/
bin/

# VS Code
.vscode/

# NetBeans
nb-configuration.xml

# ── Go (Dagger pipeline) ─────────────────────────────────────
dagger_go/railway-dagger-go
dagger_go/railway-corporate-dagger-go
dagger_go/test_run.log

# ── Binary fixtures ───────────────────────────────────────────
# src/main/resources/fixtures/masterlist_mock.bin IS committed — synthetic test blob
# (NOT a real ICAO certificate) — safe for CI pipelines and public repos.
# All other .bin files in src/ are ignored (e.g. ml_es.bin, real Master Lists).
src/main/resources/fixtures/*.bin
!src/main/resources/fixtures/masterlist_mock.bin
src/main/resources/fixtures/*.der

# deployment/fixtures/ — NEVER commit (should stay local or on staging branch via manual process)
# These fixture files are loaded imperatively into K8s Secrets, not committed.
# If staging needs them, add via a separate mechanism (e.g., git-crypt, external storage).
deployment/fixtures/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────
.dockerignore.bak
